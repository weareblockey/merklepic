{
	"name": "merklepic",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.3.1",
			"zod": "^4.3.6",
			"@types/node": "^22.19.15",
			"lucide-react": "^0.546.0",
			"react": "^19.2.4",
			"react-dom": "^19.2.4",
			"sonner": "^2.0.7",
			"tailwindcss": "^4.2.2",
			"@types/react": "^19.2.14",
			"@types/react-dom": "^19.2.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F @merklepic/web dev",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@merklepic/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@merklepic/config": "workspace:*",
		"@types/node": "catalog:",
		"shadcn": "^4.1.0",
		"turbo": "^2.8.20",
		"typescript": "^5.9.3"
	},
	"packageManager": "bun@1.3.11"
}
